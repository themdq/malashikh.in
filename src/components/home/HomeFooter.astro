---
import { meta, nav, social } from '@/data/site';
import { buildHash } from '@/data/build';

const year = new Date().getFullYear();
const elsewhere = social.filter(s => s.name !== 'telegram');
---
<footer>
  <div class="foot-brand">
    <div class="bigname">{meta.nameShort}<span class="it">.</span></div>
    <p>{meta.tagline}</p>
  </div>

  <div>
    <h5>Navigate</h5>
    <ul>
      {nav.map(item => <li><a href={item.href}>{item.label}</a></li>)}
    </ul>
  </div>

  <div>
    <h5>Elsewhere</h5>
    <ul>
      {elsewhere.map(s => (
        <li>
          <a href={s.href} target={s.href.startsWith('mailto') ? undefined : '_blank'} rel={s.href.startsWith('mailto') ? undefined : 'noopener'}>
            {s.name.charAt(0).toUpperCase() + s.name.slice(1)}
          </a>
        </li>
      ))}
      <li><a href="/blog">RSS</a></li>
    </ul>
  </div>

  <div>
    <h5>Colophon</h5>
    <ul>
      {meta.colophon.map(c => <li>{c}</li>)}
      <li>Deployed from <code style="color:var(--accent)">main</code></li>
    </ul>
  </div>

  <div class="copyline" style="grid-column:1/-1">
    <span>© {year} {meta.name} · {meta.taglineFooter}</span>
    <span class="coords">{meta.coords.lat}, {meta.coords.lon} · <span id="build-hash">build {buildHash}</span></span>
  </div>
</footer>
