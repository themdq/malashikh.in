---
let buildHash = import.meta.env.COMMIT_HASH || process.env.COMMIT_HASH;
if (!buildHash) {
  try {
    const { execSync } = await import('child_process');
    buildHash = execSync('git rev-parse --short HEAD').toString().trim();
  } catch {
    buildHash = 'unknown';
  }
}
