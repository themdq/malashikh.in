---
import { meta, hero } from '@/data/site';
---
<div>
  <div class="hello">
    <span class="caret">▌</span>
    <span>{hero.greeting}</span>
  </div>

  <h1>{meta.nameShort.charAt(0).toUpperCase() + meta.nameShort.slice(1)}<br /><span class="it">Malashikhin.</span></h1>

  <div class="role" aria-label="Roles">
    {meta.roles.map((r, i) => (
      <>
        {i > 0 && <span class="sep">//</span>}
        <span class={`tag${i === 0 ? ' primary' : ''}`}>{r}</span>
      </>
    ))}
  </div>

  <p class="desc" set:html={hero.description} />

  <div class="cta-row">
    {hero.cta.map(c => (
      <a href={c.href} class={`btn${c.primary ? ' primary' : ''}`} id={c.id}>
        {c.label} <span class="kbd">{c.kbd}</span>
      </a>
    ))}
  </div>
</div>
