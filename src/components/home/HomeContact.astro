---
import { social } from '@/data/site';
---
<section class="block" id="contact" style="padding-top:48px">
  <div class="section-head">
    <div class="num">§ 04</div>
    <h2>Let's build <span class="it">something.</span></h2>
    <div class="aux">ping me</div>
  </div>

  <div class="cta">
    <div>
      <div class="big">Open to <span class="it">interesting</span> problems.</div>
      <div class="sub">
        Data pipelines, security tooling, developer-facing automation.
        I reply within a day — usually with a small question first. Recruiters are welcome.
      </div>
    </div>
    <div class="side">
      {social.map(s => (
        <a href={s.href} target={s.href.startsWith('mailto') ? undefined : '_blank'} rel={s.href.startsWith('mailto') ? undefined : 'noopener'}>
          <span>{s.label}</span><span class="ext">{s.ext}</span>
        </a>
      ))}
    </div>
  </div>
</section>
