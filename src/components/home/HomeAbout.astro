---
import { about } from '@/data/site';
---
<section class="block" id="about">
  <div class="section-head">
    <div class="num">§ 01</div>
    <h2>About, <span class="it">briefly.</span></h2>
    <div class="aux">cat ~/README.md</div>
  </div>

  <div class="about">
    <div class="prose">
      {about.bio.paras.map(p => <p set:html={p} />)}
    </div>

    <aside class="fact-card" aria-label="Quick facts">
      <h4><span>//</span> quick_facts.yml <span>v1</span></h4>
      <div class="fact-list">
        {about.facts.map(f => (
          <div class="r" data-fact={f.k}>
            <div class="k">{f.k}</div>
            <div class="v">{f.v}{f.sub && <span class="sub"> {f.sub}</span>}</div>
          </div>
        ))}
      </div>
    </aside>
  </div>

  <div class="stats" aria-label="At a glance">
    {about.stats.map(s => (
      <div class="stat" tabindex="0">
        <div class="n" data-count={s.n}>0<span class="u">{s.u}</span></div>
        <div class="l">{s.label}</div>
        <div class="sl">{s.sub}</div>
      </div>
    ))}
  </div>
</section>
