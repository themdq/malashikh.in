---
import { now, deploys } from '@/data/site';
---
<div class="dash">
  <!-- Now panel -->
  <div class="panel" aria-label="Right now">
    <div class="phead">
      <b>// now — {now.label}</b>
      <span class="rt"><span class="dot live"></span> updated 3 min ago</span>
    </div>
    <div class="now-body">
      {now.items.map(item => (
        <div class="now-item">
          <div class="ic">{item.ic}</div>
          <div>
            <div class="k">{item.k}</div>
            <div class="v"><Fragment set:html={item.v} /><span class="sub">{item.sub}</span></div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Deploy log panel -->
  <div class="panel" aria-label="Deploy log">
    <div class="phead">
      <b>// deploys — last 7d</b>
      <span class="rt">uptime {deploys.uptime}</span>
    </div>
    <div class="log" id="log">
      {deploys.entries.map(e => (
        <div class={`row ${e.status}`}>
          <span class="t">{e.date}</span>
          <span class="s">{e.status === 'ok' ? 'OK' : e.status === 'wip' ? '..' : '!!'}</span>
          <span class="m"><Fragment set:html={e.msg} /></span>
          <span class="h">{e.dur}</span>
        </div>
      ))}
    </div>
  </div>
</div>
