---
---
<div class="dash">
  <!-- Now panel -->
  <div class="panel" aria-label="Right now">
    <div class="phead">
      <b>// now — apr 2026</b>
      <span class="rt"><span class="dot live"></span> updated 3 min ago</span>
    </div>
    <div class="now-body">
      <div class="now-item">
        <div class="ic">▶</div>
        <div>
          <div class="k">listening</div>
          <div class="v">King Krule — <i>Easy Easy</i><span class="sub">on repeat this week</span></div>
        </div>
      </div>
      <div class="now-item">
        <div class="ic">☕</div>
        <div>
          <div class="k">drinking</div>
          <div class="v">Espresso tonic<span class="sub">Café Grumpy, 3rd visit today</span></div>
        </div>
      </div>
      <div class="now-item">
        <div class="ic">✎</div>
        <div>
          <div class="k">reading</div>
          <div class="v">Designing Data-Intensive Apps<span class="sub">ch. 7 — transactions</span></div>
        </div>
      </div>
      <div class="now-item">
        <div class="ic">▲</div>
        <div>
          <div class="k">building</div>
          <div class="v">a tiny SIEM normalizer<span class="sub">weekend project · Python + DuckDB</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Deploy log panel -->
  <div class="panel" aria-label="Deploy log">
    <div class="phead">
      <b>// deploys — last 7d</b>
      <span class="rt">uptime 99.98%</span>
    </div>
    <div class="log" id="log">
      <div class="row ok"><span class="t">apr 17 09:12</span><span class="s">OK</span><span class="m">site v2.5.1 · <code>hero/ascii</code></span><span class="h">1.2s</span></div>
      <div class="row ok"><span class="t">apr 16 18:44</span><span class="s">OK</span><span class="m">blog post published</span><span class="h">0.8s</span></div>
      <div class="row ok"><span class="t">apr 15 11:03</span><span class="s">OK</span><span class="m">tg-to-drive v1.4 · <code>release</code></span><span class="h">42s</span></div>
      <div class="row wip"><span class="t">apr 14 21:17</span><span class="s">..</span><span class="m">asos-map canary → 20%</span><span class="h">—</span></div>
      <div class="row ok"><span class="t">apr 13 08:29</span><span class="s">OK</span><span class="m">cron · NVD sync</span><span class="h">3.1s</span></div>
      <div class="row err"><span class="t">apr 12 02:04</span><span class="s">!!</span><span class="m">auto-retry · upstream 502</span><span class="h">14s</span></div>
      <div class="row ok"><span class="t">apr 11 17:45</span><span class="s">OK</span><span class="m">site v2.5.0 · redesign</span><span class="h">1.4s</span></div>
    </div>
  </div>
</div>
