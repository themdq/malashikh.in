<div class="pipeline-wrap" aria-label="How I think about a project">
  <div style="font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);margin-bottom:12px;display:flex;justify-content:space-between;">
    <span>// how a pipeline flows through my desk</span>
    <span style="color:var(--accent)">observable end-to-end</span>
  </div>

  <div class="pipeline">
    <div class="node" data-tag="python"><b>01 source</b>research &amp; onboard<small>APIs · files · DBs</small></div>
    <div class="arrow"></div>
    <div class="node" data-tag="python"><b>02 normalize</b>parse &amp; shape<small>schemas · types</small></div>
    <div class="arrow"></div>
    <div class="node" data-tag="web"><b>03 enrich</b>join &amp; validate<small>NVD · rules · QA</small></div>
  </div>

  <div class="pipeline" style="margin-top:12px">
    <div class="node" style="grid-column:1 / span 1;visibility:hidden"></div>
    <div class="arrow" style="visibility:hidden"></div>
    <div class="node" data-tag="iac,tf"><b>04 deliver</b>load &amp; serve<small>product · dashboards</small></div>
    <div class="arrow"></div>
    <div class="node" data-tag="k8s,obs" style="background:var(--paper-2);border-color:var(--accent)">
      <b style="color:var(--accent)">05 operate</b>monitor &amp; support<small>SLOs · on-call</small>
    </div>
  </div>
</div>
