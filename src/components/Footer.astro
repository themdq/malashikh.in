---
import { meta, social } from '@/data/site';

const currentYear = new Date().getFullYear();
const footerSocial = social.filter(s => ['email', 'github', 'linkedin'].includes(s.name));
---

<footer class="border-t bg-background">
  <div class="container py-8 md:py-12">
    <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
      <div class="flex flex-col items-center md:items-start space-y-2">
        <span class="text-lg font-semibold">[{meta.handle}]</span>
        <p class="text-sm text-muted-foreground">
          Building things for the web
        </p>
      </div>

      <div class="flex items-center space-x-4">
        {footerSocial.map(s => (
          <a
            href={s.href}
            target={s.href.startsWith('mailto') ? undefined : '_blank'}
            rel={s.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="text-muted-foreground hover:text-foreground transition-colors"
          >
            [{s.name}]
          </a>
        ))}
      </div>
    </div>

    <div class="mt-8 pt-8 border-t text-center text-sm text-muted-foreground">
      <p>(c) {currentYear} {meta.name}</p>
    </div>
  </div>
</footer>
