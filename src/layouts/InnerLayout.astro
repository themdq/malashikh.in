---
import HomeTopbar from '@/components/home/HomeTopbar.astro';
import HomeFooter from '@/components/home/HomeFooter.astro';
import '../styles/home.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Dmitrii Malashikhin — Data Engineer',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&display=swap"
  />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta name="theme-color" content="#FFFCF0" />

  <title>{title} | Dmitrii Malashikhin</title>

  <script is:inline>
    (function () {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var dark = stored === 'dark' || (!stored && prefersDark);
      document.documentElement.dataset.dark = dark ? 'true' : 'false';
      document.documentElement.dataset.accent = localStorage.getItem('home-accent') || 'espresso';
      document.documentElement.dataset.density = localStorage.getItem('home-density') || 'comfortable';
      if (dark) document.documentElement.classList.add('dark');
    })();
  </script>
</head>
<body>
  <div class="inner-shell">
    <HomeTopbar />
    <main>
      <slot />
    </main>
    <HomeFooter />
  </div>
</body>
</html>
