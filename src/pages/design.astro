---
import HomeLayout from '@/layouts/HomeLayout.astro';
import HomeTopbar from '@/components/home/HomeTopbar.astro';

const flexokiBase = [
  { name: '--paper',     light: '#FFFCF0', dark: '#100F0F', usage: 'Page background' },
  { name: '--paper-2',   light: '#F2F0E5', dark: '#1C1B1A', usage: 'Secondary bg' },
  { name: '--paper-3',   light: '#E6E4D9', dark: '#282726', usage: 'Tertiary bg' },
  { name: '--ink',       light: '#100F0F', dark: '#FFFCF0', usage: 'Primary text' },
  { name: '--ink-2',     light: '#24231C', dark: '#CECDC3', usage: 'Secondary text' },
  { name: '--ink-3',     light: '#6F6E69', dark: '#878580', usage: 'Muted text' },
  { name: '--ink-4',     light: '#B7B5AC', dark: '#575653', usage: 'Very muted' },
  { name: '--rule',      light: '#CECDC3', dark: '#403E3C', usage: 'Borders, dividers' },
  { name: '--accent',    light: '#AF3029', dark: '#D14D41', usage: 'Primary accent' },
  { name: '--tonic',     light: '#24837B', dark: '#3AA99F', usage: 'Alt accent (cyan)' },
  { name: '--highlight', light: '#FCEEB8', dark: '#402D1A', usage: 'Selection bg' },
];

const accentSwatches = [
  { name: 'espresso', accent: '#AF3029', soft: '#D14D41' },
  { name: 'rust',     accent: '#BC5215', soft: '#DA702C' },
  { name: 'cyan',     accent: '#24837B', soft: '#3AA99F' },
  { name: 'ink',      accent: '#100F0F', soft: '#403E3C' },
];

const flexokiExtended = [
  { name: 'red',     var: '--flexoki-red' },
  { name: 'orange',  var: '--flexoki-orange' },
  { name: 'yellow',  var: '--flexoki-yellow' },
  { name: 'green',   var: '--flexoki-green' },
  { name: 'cyan',    var: '--flexoki-cyan' },
  { name: 'blue',    var: '--flexoki-blue' },
  { name: 'purple',  var: '--flexoki-purple' },
  { name: 'magenta', var: '--flexoki-magenta' },
];

const typeScale = [
  { size: '10px', usage: 'Labels, chips, uppercase UI',   font: 'mono',  letterSpacing: '0.16em',  transform: 'uppercase' },
  { size: '12px', usage: 'Nav, captions',                 font: 'mono',  letterSpacing: '0.02em',  transform: 'none' },
  { size: '14px', usage: 'Body text',                     font: 'mono',  letterSpacing: '0.02em',  transform: 'none' },
  { size: '24px', usage: 'Card titles',                   font: 'serif', letterSpacing: '-0.01em', transform: 'none' },
  { size: '28px', usage: 'Project headings',              font: 'serif', letterSpacing: '-0.01em', transform: 'none' },
  { size: '42px', usage: 'Section h2 (max)',              font: 'serif', letterSpacing: '-0.02em', transform: 'none' },
  { size: '72px', usage: 'Hero h1 (min)',                 font: 'serif', letterSpacing: '-0.02em', transform: 'none' },
];

const spacingScale = [4, 8, 12, 16, 24, 32, 48, 72, 96];

const homeComponents = [
  {
    name: 'HomeHero',
    file: 'src/components/home/HomeHero.astro',
    description: 'Full-width hero with name, role tags, bio, and CTA buttons with keyboard shortcut hints.',
    anchor: '/#hero',
  },
  {
    name: 'HomeTicker',
    file: 'src/components/home/HomeTicker.tsx',
    description: 'Scrolling ticker + interactive pinboard. Pointer-driven speed, drag-to-pin, localStorage persistence.',
    anchor: '/#ticker',
  },
  {
    name: 'AsciiPortrait',
    file: 'src/components/home/AsciiPortrait.tsx',
    description: '72-line ASCII art with mouse-reactive fade, idle sweep animation, draggable with fling physics.',
    anchor: '/#hero',
  },
  {
    name: 'HomeTerminal',
    file: 'src/components/home/HomeTerminal.tsx',
    description: 'In-page command terminal with 11 commands (help, whoami, ls, stack, now, projects, theme, accent…). Opens on `:` or backtick.',
    anchor: '/#terminal',
  },
  {
    name: 'CommandPalette',
    file: 'src/components/home/CommandPalette.tsx',
    description: 'Cmd+K modal with 14 commands across 4 groups (Navigate, Action, Theme, Fun). Search-filtered, keyboard-navigable.',
    anchor: '/',
  },
  {
    name: 'HomePipeline',
    file: 'src/components/home/HomePipeline.astro',
    description: '5-stage data pipeline diagram (source → normalize → enrich → deliver → operate) with color-coded tech tags.',
    anchor: '/#pipeline',
  },
  {
    name: 'HomeNowDeploys',
    file: 'src/components/home/HomeNowDeploys.astro',
    description: '2-panel dashboard: current activities (Now) and auto-generated deploy log from git history.',
    anchor: '/#now',
  },
  {
    name: 'KonamiOverlay',
    file: 'src/components/home/KonamiOverlay.tsx',
    description: 'Modal with personal anecdotes revealed by ↑↑↓↓←→←→BA sequence.',
    anchor: '/',
  },
];

const keyboardShortcuts = [
  { key: 'j / k',        action: 'Navigate between sections' },
  { key: 'w',            action: 'Jump to projects' },
  { key: 'c',            action: 'Jump to contact' },
  { key: 'd',            action: 'Toggle dark mode' },
  { key: ': or `',       action: 'Open terminal' },
  { key: 'Cmd+K',        action: 'Open command palette' },
  { key: '↑↑↓↓←→←→BA',  action: 'Konami easter egg' },
];
---

<HomeLayout title="Design System" description="Visual design language of malashikh.in — tokens, components, and patterns.">
  <HomeTopbar />

  <!-- INTRO -->
  <section class="block" id="top" style="padding-top: 32px; padding-bottom: 0;">
    <div class="section-head">
      <div class="num">§ 00</div>
      <h2>Design <span class="it">system.</span></h2>
    </div>
    <p style="color: var(--ink-2); font-size: 13px; max-width: 60ch; line-height: 1.6; margin-bottom: 24px;">
      The visual language of malashikh.in. Flexoki palette, JetBrains Mono + Instrument Serif,
      zero border-radius, CSS custom properties, and a sharp functional aesthetic.
    </p>
    <nav class="ds-nav">
      <a href="#colors">→ colors</a>
      <a href="#typography">→ typography</a>
      <a href="#spacing">→ spacing</a>
      <a href="#components">→ components</a>
      <a href="#home-components">→ home components</a>
      <a href="#patterns">→ patterns</a>
    </nav>
  </section>

  <!-- 01 COLORS -->
  <section class="block" id="colors">
    <div class="section-head">
      <div class="num">§ 01</div>
      <h2>Color <span class="it">tokens.</span></h2>
    </div>

    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead">
        <b>Flexoki Base</b>
        <span class="rt">home.css · light / dark pairs</span>
      </div>
      <div style="padding: 14px 18px; display: grid; gap: 6px;">
        {flexokiBase.map(token => (
          <div class="ds-palette-row">
            <code class="ds-var">{token.name}</code>
            <span class="ds-usage">{token.usage}</span>
            <div class="ds-swatch" style={`background: ${token.light};`}></div>
            <code class="ds-hex">{token.light}</code>
            <div class="ds-swatch" style={`background: ${token.dark}; border-color: var(--rule);`}></div>
            <code class="ds-hex">{token.dark}</code>
          </div>
        ))}
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
      <div class="panel">
        <div class="phead">
          <b>Accent Swatches</b>
          <span class="rt">data-accent="{'{name}'}"</span>
        </div>
        <div style="padding: 14px 18px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
          {accentSwatches.map(s => (
            <div style="border: 1px solid var(--rule);">
              <div style={`height: 36px; background: ${s.accent};`}></div>
              <div style="padding: 6px 8px;">
                <p style="font-size: 11px; font-weight: 600; color: var(--ink); margin: 0 0 2px;">{s.name}</p>
                <code style="font-size: 10px; color: var(--ink-3); font-family: var(--mono);">{s.accent}</code>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="panel">
        <div class="phead">
          <b>Flexoki Extended</b>
          <span class="rt">global.css · hsl(var(--flexoki-*))</span>
        </div>
        <div style="padding: 14px 18px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
          {flexokiExtended.map(color => (
            <div>
              <div style={`height: 28px; width: 100%; background: hsl(var(${color.var})); border: 1px solid var(--rule); margin-bottom: 4px;`}></div>
              <p style="font-size: 10px; color: var(--ink-3);">{color.name}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 02 TYPOGRAPHY -->
  <section class="block" id="typography">
    <div class="section-head">
      <div class="num">§ 02</div>
      <h2>Type<span class="it">face.</span></h2>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
      <div class="panel">
        <div class="phead"><b>JetBrains Mono</b><span class="rt">--mono · body + UI</span></div>
        <div style="padding: 16px 18px;">
          <p style="font-family: var(--mono); font-size: 22px; color: var(--ink); line-height: 1.3; margin: 0 0 8px;">Aa Bb 01 23 !?</p>
          <p style="font-family: var(--mono); font-size: 12.5px; color: var(--ink-2); line-height: 1.55; margin: 0 0 10px;">
            The quick brown fox jumps over the lazy dog.
          </p>
          <p style="font-size: 11px; color: var(--ink-3);">Body, labels, UI, code, nav. <code style="background: var(--paper-3); padding: 1px 4px; font-family: var(--mono);">ss01 cv11</code></p>
        </div>
      </div>
      <div class="panel">
        <div class="phead"><b>Instrument Serif</b><span class="rt">--serif · display + headings</span></div>
        <div style="padding: 16px 18px;">
          <p style="font-family: var(--serif); font-size: 28px; color: var(--ink); line-height: 1.1; margin: 0 0 8px; font-style: italic;">Aa Bb 01 23 !?</p>
          <p style="font-family: var(--serif); font-size: 16px; color: var(--ink-2); line-height: 1.4; margin: 0 0 10px; font-style: italic;">
            The quick brown fox jumps over the lazy dog.
          </p>
          <p style="font-size: 11px; color: var(--ink-3);">Display headings, hero, section titles. Italic for decorative emphasis.</p>
        </div>
      </div>
    </div>

    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead"><b>Type Scale</b></div>
      <div style="padding: 16px 18px; display: grid; gap: 18px; overflow: hidden;">
        {typeScale.map(step => (
          <div style="display: flex; align-items: baseline; gap: 16px;">
            <span style="font-size: 10px; color: var(--ink-3); width: 36px; flex-shrink: 0; font-variant-numeric: tabular-nums;">{step.size}</span>
            <p style={`font-size: ${step.size}; font-family: ${step.font === 'serif' ? 'var(--serif)' : 'var(--mono)'}; letter-spacing: ${step.letterSpacing}; text-transform: ${step.transform}; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 500px; margin: 0; flex: 1;`}>
              Aa — {step.usage}
            </p>
            <span style="font-size: 10px; color: var(--ink-4); flex-shrink: 0; margin-left: auto;">{step.font}</span>
          </div>
        ))}
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div class="panel">
        <div class="phead"><b>Letter Spacing</b></div>
        <div style="padding: 14px 18px; display: grid; gap: 0;">
          {[
            { em: '−0.02em', s: 'letter-spacing:-0.02em',                           label: 'Display headings' },
            { em: '0em',     s: '',                                                  label: 'Body default' },
            { em: '0.02em',  s: 'letter-spacing:0.02em',                            label: 'Body, small labels' },
            { em: '0.08em',  s: 'letter-spacing:0.08em',                            label: 'Nav links' },
            { em: '0.16em',  s: 'letter-spacing:0.16em;text-transform:uppercase;font-size:10px', label: 'Section labels' },
          ].map(row => (
            <div style="display: flex; align-items: center; gap: 12px; padding: 9px 0; border-bottom: 1px dashed var(--rule-soft);">
              <span style="font-size: 10px; color: var(--ink-3); width: 54px; flex-shrink: 0;">{row.em}</span>
              <span style={row.s}>Brown fox</span>
              <span style="font-size: 10px; color: var(--ink-4); margin-left: auto; flex-shrink: 0;">{row.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="panel">
        <div class="phead"><b>Line Height</b></div>
        <div style="padding: 14px 18px; display: grid; gap: 14px;">
          <div>
            <p style="font-size: 10px; color: var(--ink-3); margin: 0 0 6px; text-transform: uppercase; letter-spacing: .1em;">0.92 — Headings</p>
            <p style="font-family: var(--serif); font-size: 21px; line-height: 0.92; border: 1px solid var(--rule); padding: 12px; background: var(--paper-2); margin: 0;">
              Display heading with tight line height stacked
            </p>
          </div>
          <div>
            <p style="font-size: 10px; color: var(--ink-3); margin: 0 0 6px; text-transform: uppercase; letter-spacing: .1em;">1.55 — Body</p>
            <p style="font-size: 13px; line-height: 1.55; border: 1px solid var(--rule); padding: 12px; background: var(--paper-2); margin: 0; color: var(--ink-2);">
              Body text with comfortable reading line height. Spacing improves legibility for long-form content.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 03 SPACING -->
  <section class="block" id="spacing">
    <div class="section-head">
      <div class="num">§ 03</div>
      <h2>Spacing <span class="it">&amp; layout.</span></h2>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: 16px;">
      <div class="panel">
        <div class="phead"><b>Spacing Scale</b></div>
        <div style="padding: 14px 18px; display: grid; gap: 10px;">
          {spacingScale.map(size => (
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="font-size: 10px; color: var(--ink-3); width: 36px; flex-shrink: 0; font-variant-numeric: tabular-nums;">{size}px</span>
              <div style={`height: 10px; width: ${size}px; min-width: ${size}px; background: var(--ink);`}></div>
            </div>
          ))}
        </div>
      </div>

      <div style="display: flex; flex-direction: column; gap: 16px;">
        <div class="panel">
          <div class="phead"><b>Container</b></div>
          <div style="padding: 10px 18px; font-size: 11.5px;">
            {[
              ['max-width', '1240px'],
              ['horizontal padding', '32px'],
              ['border-radius', '0px (enforced everywhere)'],
            ].map(([k, v]) => (
              <div style="display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 1px dashed var(--rule-soft);">
                <span style="color: var(--ink-3);">{k}</span>
                <code style="font-family: var(--mono); font-size: 11px; color: var(--ink-2);">{v}</code>
              </div>
            ))}
          </div>
        </div>

        <div class="panel">
          <div class="phead"><b>Grid Patterns</b></div>
          <div style="padding: 10px 18px; font-size: 11px; display: grid; gap: 10px;">
            {[
              { label: 'Hero',      cols: '1.2fr 1fr' },
              { label: 'Projects',  cols: 'repeat(3, 1fr)' },
              { label: 'Dashboard', cols: '1.2fr 1fr' },
              { label: 'Blog',      cols: '110px 1fr auto' },
              { label: 'Footer',    cols: '2fr 1fr 1fr 1fr' },
            ].map(({ label, cols }) => (
              <div style="display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px dashed var(--rule-soft);">
                <span style="color: var(--ink-3);">{label}</span>
                <code style="font-family: var(--mono); color: var(--accent); font-size: 10.5px;">{cols}</code>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 04 COMPONENTS -->
  <section class="block" id="components">
    <div class="section-head">
      <div class="num">§ 04</div>
      <h2>UI <span class="it">components.</span></h2>
    </div>

    <!-- Buttons -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead"><b>Buttons — .btn</b></div>
      <div style="padding: 20px 18px; display: flex; flex-wrap: wrap; gap: 12px; align-items: center; border-bottom: 1px solid var(--rule);">
        <button class="btn">default</button>
        <button class="btn primary">primary</button>
        <button class="btn" style="opacity: .4; pointer-events: none;">disabled</button>
        <button class="btn">view projects <span class="kbd">W</span></button>
      </div>
      <pre class="ds-code"><code>{`<button class="btn">default</button>
<button class="btn primary">primary</button>
<button class="btn">label <span class="kbd">W</span></button>`}</code></pre>
    </div>

    <!-- Tags + chips -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead"><b>Tags &amp; Chips</b></div>
      <div style="padding: 20px 18px; display: flex; flex-wrap: wrap; gap: 24px; align-items: center; border-bottom: 1px solid var(--rule);">
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <span style="font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: .12em;">.role .tag</span>
          <div style="display: flex; gap: 6px; align-items: center;">
            <span class="ds-tag">Python</span>
            <span class="ds-tag">Kafka</span>
            <span class="ds-tag ds-tag-primary">data-eng</span>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <span style="font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: .12em;">.chip</span>
          <div style="display: flex; gap: 8px; align-items: center;">
            <span class="chip"><span class="dot live"></span>available</span>
            <span class="chip"><span class="dot"></span>idle</span>
          </div>
        </div>
      </div>
      <pre class="ds-code"><code>{`<span class="chip"><span class="dot live"></span>available</span>
<span class="ds-tag">Python</span>
<span class="ds-tag ds-tag-primary">accent tag</span>`}</code></pre>
    </div>

    <!-- Panel -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead"><b>Panel — .panel</b><span class="rt">primary container primitive</span></div>
      <div style="padding: 14px 18px; font-size: 12.5px; color: var(--ink-2); border-bottom: 1px solid var(--rule);">
        <p style="margin: 0 0 10px; line-height: 1.6;">
          Uses <code style="background: var(--paper-3); padding: 1px 5px; font-family: var(--mono); font-size: 11px;">.phead</code> for the header bar,
          <code style="background: var(--paper-3); padding: 1px 5px; font-family: var(--mono); font-size: 11px;">&lt;b&gt;</code> for title,
          and <code style="background: var(--paper-3); padding: 1px 5px; font-family: var(--mono); font-size: 11px;">.rt</code> for right-side aux text.
        </p>
      </div>
      <pre class="ds-code"><code>{`<div class="panel">
  <div class="phead">
    <b>Title</b>
    <span class="rt">aux info</span>
  </div>
  <!-- content -->
</div>`}</code></pre>
    </div>

    <!-- Fact card + Stats -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
      <div>
        <p style="font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 8px;">.fact-card</p>
        <div class="fact-card">
          <h4>Quick facts <span>✦</span></h4>
          <div class="fact-list">
            <div class="r">
              <span class="k">location</span>
              <span class="v">New York, NY</span>
            </div>
            <div class="r">
              <span class="k">role</span>
              <span class="v">Data Engineer <span class="sub">pipeline infra</span></span>
            </div>
            <div class="r">
              <span class="k">stack</span>
              <span class="v">Python · Kafka · k8s</span>
            </div>
          </div>
        </div>
      </div>
      <div>
        <p style="font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 8px;">.stats · .stat</p>
        <div class="stats" style="grid-template-columns: repeat(2, 1fr);">
          <div class="stat">
            <div class="n">5<span class="u">yr</span></div>
            <div class="l">experience</div>
            <div class="sl">data engineering</div>
          </div>
          <div class="stat">
            <div class="n">3<span class="u">×</span></div>
            <div class="l">pipelines</div>
            <div class="sl">production scale</div>
          </div>
        </div>
        <p style="font-size: 11px; color: var(--ink-3); margin-top: 8px; line-height: 1.5;">
          Hover a stat to see the accent underline animation.
        </p>
      </div>
    </div>
  </section>

  <!-- 05 HOME COMPONENTS -->
  <section class="block" id="home-components">
    <div class="section-head">
      <div class="num">§ 05</div>
      <h2>Home <span class="it">components.</span></h2>
      <div class="aux"><a href="/" style="border-bottom: 1px solid var(--accent);">see live →</a></div>
    </div>
    <p style="font-size: 13px; color: var(--ink-2); margin-bottom: 20px; max-width: 60ch; line-height: 1.6;">
      Interactive showcase components used exclusively on the homepage (<code style="background: var(--paper-3); padding: 1px 5px; font-family: var(--mono); font-size: 11px;">/</code>).
      They use the Flexoki base palette from <code style="background: var(--paper-3); padding: 1px 5px; font-family: var(--mono); font-size: 11px;">src/styles/home.css</code>.
    </p>
    <div style="display: grid; gap: 8px;">
      {homeComponents.map(comp => (
        <div class="panel">
          <div class="phead">
            <b>{comp.name}</b>
            <span class="rt">
              <code style="font-family: var(--mono); font-size: 10px; color: var(--ink-3);">{comp.file}</code>
              <a href={comp.anchor} style="color: var(--accent); font-size: 11px; margin-left: 14px;">see live →</a>
            </span>
          </div>
          <div style="padding: 10px 14px; font-size: 12px; color: var(--ink-2);">{comp.description}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 06 PATTERNS -->
  <section class="block" id="patterns">
    <div class="section-head">
      <div class="num">§ 06</div>
      <h2>Interaction <span class="it">patterns.</span></h2>
    </div>

    <!-- Keyboard shortcuts -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead">
        <b>Keyboard Shortcuts</b>
        <span class="rt">homepage only</span>
      </div>
      <div>
        {keyboardShortcuts.map(s => (
          <div style="display: grid; grid-template-columns: 180px 1fr; align-items: center; padding: 10px 18px; border-bottom: 1px dashed var(--rule-soft);">
            <kbd style="border: 1px solid var(--ink-4); padding: 2px 8px; font-size: 11px; background: var(--paper-2); color: var(--ink-2); font-family: var(--mono); width: fit-content;">{s.key}</kbd>
            <span style="font-size: 12px; color: var(--ink-2);">{s.action}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Hover patterns -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead"><b>Hover Patterns</b></div>
      <div style="padding: 20px 18px; display: flex; flex-direction: column; gap: 14px;">
        <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
          <a href="#" class="ds-hover-shadow" style="border: 1px solid var(--rule); padding: 10px 14px; font-size: 13px; display: block; transition: all .15s;">
            Translate + shadow
          </a>
          <code style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">translate(-2,-2) + box-shadow var(--accent)</code>
        </div>
        <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
          <a href="#" class="ds-hover-border" style="border: 1px solid var(--rule); padding: 10px 14px; font-size: 13px; display: block; transition: border-color .15s;">
            Border shift
          </a>
          <code style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">hover: border-color → var(--ink)</code>
        </div>
        <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
          <a href="#" class="ds-hover-pad" style="padding: 10px 14px; font-size: 13px; display: block; transition: padding .15s; color: var(--ink-2);">
            → Left-pad slide
          </a>
          <code style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">hover: padding-left (blog post rows)</code>
        </div>
        <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
          <a href="#" class="ds-hover-cyan" style="padding: 10px 0; font-size: 13px; display: block; transition: color .15s; color: var(--ink-2);">
            Color shift → tonic
          </a>
          <code style="font-size: 11px; color: var(--ink-3); font-family: var(--mono);">hover: color → var(--tonic)</code>
        </div>
      </div>
    </div>

    <!-- Dark mode -->
    <div class="panel" style="margin-bottom: 16px;">
      <div class="phead"><b>Dark Mode</b></div>
      <div style="padding: 10px 18px; font-size: 11.5px;">
        {[
          ['Strategy',               'class + data-dark attribute (not prefers-color-scheme)'],
          ['Toggle target',          'document.documentElement.dataset.dark = "true"/"false"'],
          ['Persistence',            'localStorage: theme · home-accent · home-density'],
          ['Meta theme-color light', '#FFFCF0 (--paper)'],
          ['Meta theme-color dark',  '#100F0F (--paper dark)'],
        ].map(([k, v]) => (
          <div style="display: flex; justify-content: space-between; gap: 24px; padding: 8px 0; border-bottom: 1px dashed var(--rule-soft);">
            <span style="color: var(--ink-3); flex-shrink: 0;">{k}</span>
            <code style="font-family: var(--mono); font-size: 10.5px; color: var(--ink-2); text-align: right;">{v}</code>
          </div>
        ))}
      </div>
    </div>

    <!-- Selection + Focus -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div class="panel">
        <div class="phead"><b>Text Selection</b></div>
        <div style="padding: 16px 18px;">
          <p class="ds-selection-demo" style="font-size: 13px; line-height: 1.55; color: var(--ink-2); border: 1px solid var(--rule); padding: 12px; background: var(--paper-2);">
            Select this text to see the custom selection style.
            Uses <code style="font-family: var(--mono);">--accent</code> background and <code style="font-family: var(--mono);">--paper</code> color.
          </p>
        </div>
      </div>
      <div class="panel">
        <div class="phead"><b>Focus Style</b></div>
        <div style="padding: 16px 18px;">
          <p style="font-size: 11px; color: var(--ink-3); margin-bottom: 12px;">Tab to focus — bracket style from home.css applies site-wide.</p>
          <a href="#" style="font-size: 13px; color: var(--ink-2);">Tab to focus me</a>
          <p style="font-size: 11px; color: var(--ink-3); margin-top: 16px; line-height: 1.5;">
            <code style="font-family: var(--mono); font-size: 10.5px; background: var(--paper-3); padding: 1px 4px;">::before {'{ content: "[" }'}</code><br />
            <code style="font-family: var(--mono); font-size: 10.5px; background: var(--paper-3); padding: 1px 4px;">::after  {'{ content: "]" }'}</code>
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="kbd-legend" aria-hidden="true">
    <span><kbd>⌘K</kbd> palette</span><span class="sep">·</span>
    <span><kbd>J</kbd>/<kbd>K</kbd> scroll</span><span class="sep">·</span>
    <span><kbd>:</kbd> terminal</span><span class="sep">·</span>
    <span><kbd>D</kbd> dark</span>
  </div>
</HomeLayout>

<style is:global>
  /* Design page nav */
  .ds-nav {
    display: flex; flex-wrap: wrap; gap: 4px 20px;
    font-size: 12px; border-top: 1px dashed var(--rule); padding-top: 16px;
  }
  .ds-nav a { color: var(--ink-3); transition: color .15s; }
  .ds-nav a:hover { color: var(--accent); }

  /* Palette table row */
  .ds-palette-row {
    display: grid;
    grid-template-columns: 130px 1fr 24px auto 24px auto;
    align-items: center; gap: 8px; font-size: 11px;
    padding: 3px 0; border-bottom: 1px dashed var(--rule-soft);
  }
  .ds-var   { color: var(--accent); font-family: var(--mono); }
  .ds-usage { color: var(--ink-3); }
  .ds-swatch { width: 24px; height: 20px; border: 1px solid var(--rule); flex-shrink: 0; }
  .ds-hex   { color: var(--ink-3); font-size: 10px; font-family: var(--mono); }

  /* Tag demo (scoped to design page to avoid leaking into .role / .project) */
  .ds-tag {
    font-size: 10px; padding: 2px 7px;
    border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink-3); letter-spacing: .04em;
  }
  .ds-tag-primary { border-color: var(--accent); color: var(--accent); }

  /* Code block */
  .ds-code {
    background: var(--paper-2); border-top: 1px solid var(--rule);
    padding: 12px 18px; font-size: 11px; overflow-x: auto; margin: 0;
    font-family: var(--mono); color: var(--ink-2); line-height: 1.6;
  }

  /* Hover demos */
  .ds-hover-shadow:hover {
    border-color: var(--ink) !important;
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0 var(--accent);
  }
  .ds-hover-border:hover { border-color: var(--ink) !important; }
  .ds-hover-pad:hover    { padding-left: 24px !important; }
  .ds-hover-cyan:hover   { color: var(--tonic) !important; }

  /* Selection demo */
  .ds-selection-demo::selection,
  .ds-selection-demo *::selection {
    background: var(--accent);
    color: var(--paper);
  }

  @media (max-width: 900px) {
    .ds-palette-row { grid-template-columns: 110px 1fr 20px 20px; }
    .ds-hex, .ds-usage { display: none; }
  }
</style>
