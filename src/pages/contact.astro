---
import InnerLayout from '@/layouts/InnerLayout.astro';
import ContactForm from '@/components/ContactForm';
import { social, contactPage } from '@/data/site';

const contactLinks = social.map(s => ({
  name: s.name.charAt(0).toUpperCase() + s.name.slice(1),
  value: s.label,
  href: s.href,
  label: `[${s.name}]`,
}));
---

<InnerLayout title="Contact" description="Get in touch with Dmitrii Malashikhin.">
  <div class="page-head">
    <div class="pg-num">§ 06 — contact</div>
    <h1>Get in <span class="it">touch</span></h1>
    <p class="subtitle">Have a question or want to work together? I'd love to hear from you.</p>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start">
    <!-- Contact Form -->
    <div>
      <div class="section-block" style="padding-top:0">
        <h2>Send a message</h2>
        <div class="panel">
          <div class="phead"><b>message</b></div>
          <div style="padding:20px 22px">
            <ContactForm client:load accessKey={contactPage.form.accessKey} />
          </div>
        </div>
      </div>
    </div>

    <!-- Links -->
    <div>
      <div class="section-block" style="padding-top:0">
        <h2>Other ways to connect</h2>
        {contactLinks.map((info) => (
          <a
            href={info.href}
            target={info.href.startsWith('mailto') ? undefined : '_blank'}
            rel={info.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="contact-link"
          >
            <span class="cl-label">{info.label}</span>
            <span>
              <div class="cl-name">{info.name}</div>
              <div class="cl-val">{info.value}</div>
            </span>
          </a>
        ))}

        <div class="entry" style="margin-top:24px">
          <div class="e-title" style="font-size:16px;margin-bottom:8px">Response time</div>
          <div class="e-body">{contactPage.responseTime}</div>
        </div>
      </div>
    </div>
  </div>
</InnerLayout>

<style>
  @media (max-width: 700px) {
    div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
