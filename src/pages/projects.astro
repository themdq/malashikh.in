---
import InnerLayout from '@/layouts/InnerLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---

<InnerLayout title="Projects" description="A showcase of recent projects and work by Dmitrii Malashikhin.">
  <div class="page-head">
    <div class="pg-num">§ 03 — work</div>
    <h1>Selected <span class="it">projects</span></h1>
    <p class="subtitle">A selection of projects I've worked on. Each one taught me something new.</p>
  </div>

  <div class="project-grid">
    {projects.map((project) => (
      <div class="project">
        <div class="p-head">
          <span class="st">
            <span class="sdot"></span>
            active
          </span>
          <div style="display:flex;gap:12px">
            {project.data.github && (
              <a
                href={project.data.github}
                target="_blank"
                rel="noopener noreferrer"
                style="color:var(--ink-3);font-size:11px;letter-spacing:.06em;transition:color .15s"
                onmouseover="this.style.color='var(--accent)'"
                onmouseout="this.style.color='var(--ink-3)'"
              >
                [github]
              </a>
            )}
            {project.data.demo && (
              <a
                href={project.data.demo}
                target="_blank"
                rel="noopener noreferrer"
                style="color:var(--ink-3);font-size:11px;letter-spacing:.06em;transition:color .15s"
                onmouseover="this.style.color='var(--accent)'"
                onmouseout="this.style.color='var(--ink-3)'"
              >
                [demo]
              </a>
            )}
          </div>
        </div>

        <h3>{project.data.title}</h3>
        <p>{project.data.description}</p>

        <div class="tags">
          {project.data.tech.map((t: string) => (
            <span class="tag">{t}</span>
          ))}
        </div>

        <div class="p-foot">
          <span></span>
          <span class="go">view →</span>
        </div>
      </div>
    ))}
  </div>
</InnerLayout>
