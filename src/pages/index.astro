---
import HomeLayout from '@/layouts/HomeLayout.astro';
import HomeTopbar from '@/components/home/HomeTopbar.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import HomeAbout from '@/components/home/HomeAbout.astro';
import HomePipeline from '@/components/home/HomePipeline.astro';
import HomeProjectGrid from '@/components/home/HomeProjectGrid.astro';
import HomeNowDeploys from '@/components/home/HomeNowDeploys.astro';
import HomeBlog from '@/components/home/HomeBlog.astro';
import HomeContact from '@/components/home/HomeContact.astro';
import HomeFooter from '@/components/home/HomeFooter.astro';

import AsciiPortrait from '@/components/home/AsciiPortrait';
import HomeTicker from '@/components/home/HomeTicker';
import HomeInteractions from '@/components/home/HomeInteractions';
import CommandPalette from '@/components/home/CommandPalette';
import HomeTerminal from '@/components/home/HomeTerminal';
import KonamiOverlay from '@/components/home/KonamiOverlay';

import { getCollection } from 'astro:content';
import { meta, about, now, social, ticker as tickerItems } from '@/data/site';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const siteData = {
  meta: {
    name: meta.name,
    role: meta.role,
    location: meta.location,
    email: meta.email,
  },
  about: {
    lead: about.bio.lead,
    paras: about.bio.parasPlain,
    facts: about.facts,
  },
  now: {
    label: now.label,
    items: now.items,
  },
  projects: featuredProjects.map(p => ({
    year: String(new Date().getFullYear()),
    title: p.data.title,
    desc: p.data.description,
  })),
  contact: {
    links: social.map(s => ({ label: s.label, href: s.href, ext: s.ext })),
  },
};
---

<HomeLayout>
  <!-- ── TOPBAR ── -->
  <HomeTopbar />

  <!-- ── HERO ── -->
  <section class="hero" id="top">
    <div class="sidemeta">LAT 40.7128° · LONG 74.0060° · PIPELINE NODE 04</div>
    <HomeHero />
    <AsciiPortrait client:load />
  </section>

  <!-- ── TICKER + PINBOARD ── -->
  <HomeTicker client:load items={tickerItems} />

  <!-- ── ABOUT ── -->
  <HomeAbout />

  <!-- ── PROJECTS ── -->
  <section class="block" id="projects">
    <div class="section-head">
      <div class="num">§ 02</div>
      <h2>Featured <span class="it">projects.</span></h2>
      <div class="aux">
        <a href="/projects" style="border-bottom:1px solid var(--accent)">view all →</a>
      </div>
    </div>

    <HomePipeline />
    <HomeProjectGrid projects={featuredProjects} />
    <HomeNowDeploys />
  </section>

  <!-- ── BLOG ── -->
  <HomeBlog posts={recentPosts} />

  <!-- ── CONTACT ── -->
  <HomeContact />

  <!-- ── FOOTER ── -->
  <HomeFooter />

  <!-- ── OVERLAYS & INTERACTIONS (React, client-side) ── -->
  <HomeInteractions client:load />
  <CommandPalette client:load />
  <HomeTerminal client:load siteData={siteData} />
  <KonamiOverlay client:load />

  <!-- ── KEYBOARD LEGEND ── -->
  <div class="kbd-legend" aria-hidden="true">
    <span><kbd>⌘K</kbd> palette</span><span class="sep">·</span>
    <span><kbd>J</kbd>/<kbd>K</kbd> sections</span><span class="sep">·</span>
    <span><kbd>:</kbd> terminal</span><span class="sep">·</span>
    <span><kbd>D</kbd> dark</span>
  </div>
</HomeLayout>
