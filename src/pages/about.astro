---
import InnerLayout from '@/layouts/InnerLayout.astro';
import { meta, about, experience, education } from '@/data/site';
---

<InnerLayout title="About" description={`${meta.name} — background, experience, and interests.`}>
  <div class="page-head">
    <div class="pg-num">§ 01 — about</div>
    <h1>Who I <span class="it">am</span></h1>
    <p class="subtitle">Pipeline/data engineer with a cybersecurity background, focused on automation and reliable systems.</p>
  </div>

  <!-- Bio -->
  <div class="section-block">
    <h2>Background</h2>
    <div style="font-size:15px;line-height:1.75;color:var(--ink-2);max-width:68ch">
      {about.prose.map(p => <p style="margin:0 0 1em">{p}</p>)}
    </div>
  </div>

  <!-- Experience -->
  <div class="section-block">
    <h2>Experience</h2>
    {experience.map((job) => (
      <div class="entry">
        <div class="e-head">
          <div>
            <div class="e-title">{job.title}</div>
            <div class="e-sub">{job.company}</div>
          </div>
          <span class="e-period">{job.period}</span>
        </div>
        <div class="e-body">{job.description}</div>
      </div>
    ))}
  </div>

  <!-- Education -->
  <div class="section-block">
    <h2>Education</h2>
    <div class="entry-grid">
      {education.map((edu) => (
        <div class="entry">
          <div class="e-title" style="font-size:18px">{edu.degree}</div>
          <div class="e-sub" style="margin-top:6px">{edu.school} &middot; {edu.year}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Interests -->
  <div class="section-block">
    <h2>Interests</h2>
    <div class="tag-cloud">
      {about.interests.map((interest) => (
        <span class="tag">{interest}</span>
      ))}
    </div>
  </div>
</InnerLayout>
