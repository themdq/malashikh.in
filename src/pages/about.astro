---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { meta, about, experience, education } from '@/data/site';
---

<BaseLayout title="About" description={`Learn more about ${meta.name} - background, experience, and interests.`}>
  <section class="container py-12 md:py-24">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="space-y-4 mb-12">
        <h1 class="text-4xl font-bold tracking-tight">About Me</h1>
        <p class="text-xl text-muted-foreground">
          Pipeline/data engineer with a cybersecurity background, focused on automation and reliable systems.
        </p>
      </div>

      <!-- Bio -->
      <div class="prose prose-neutral dark:prose-invert max-w-none mb-16">
        {about.prose.map(p => <><p>{p}</p><br /></>)}
      </div>

      <!-- Experience -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold tracking-tight mb-6">Experience</h2>
        <div class="space-y-6">
          {experience.map((job) => (
            <Card>
              <CardHeader>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2">
                  <div>
                    <CardTitle>{job.title}</CardTitle>
                    <CardDescription>{job.company}</CardDescription>
                  </div>
                  <Badge variant="outline">{job.period}</Badge>
                </div>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground">{job.description}</p>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold tracking-tight mb-6">Education</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {education.map((edu) => (
            <Card>
              <CardHeader>
                <CardTitle className="text-lg">{edu.degree}</CardTitle>
                <CardDescription>{edu.school} &bull; {edu.year}</CardDescription>
              </CardHeader>
            </Card>
          ))}
        </div>
      </div>

      <!-- Interests -->
      <div>
        <h2 class="text-2xl font-bold tracking-tight mb-6">Interests</h2>
        <div class="flex flex-wrap gap-3">
          {about.interests.map((interest) => (
            <Badge variant="secondary" className="text-sm py-1.5 px-4">{interest}</Badge>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
