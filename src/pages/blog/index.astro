---
import InnerLayout from '@/layouts/InnerLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
}
---

<InnerLayout title="Blog" description="Thoughts on software development, DevOps, and technology.">
  <div class="page-head">
    <div class="pg-num">§ 05 — writing</div>
    <h1>The <span class="it">blog</span></h1>
    <p class="subtitle">Thoughts, tutorials, and life in USA.</p>
  </div>

  {posts.length > 0 ? (
    <div class="posts">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="post">
          <span class="date">{fmtDate(post.data.date)}</span>
          <span>
            <span class="title">{post.data.title}</span>
            <span class="sub">{post.data.excerpt}</span>
          </span>
          <span class="tags">
            {post.data.tags.slice(0, 2).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        </a>
      ))}
    </div>
  ) : (
    <div style="padding:48px 0;color:var(--ink-3);font-size:13px">
      No posts yet — check back soon.
    </div>
  )}
</InnerLayout>
