---
import InnerLayout from '@/layouts/InnerLayout.astro';

const levels = { expert: 4, advanced: 3, intermediate: 2, beginner: 1 } as const;
type Level = keyof typeof levels;

const skillCategories = [
  {
    name: 'Languages',
    icon: '[lang]',
    skills: [
      { name: 'TypeScript', level: 'advanced' as Level },
      { name: 'Python', level: 'expert' as Level },
      { name: 'C++', level: 'intermediate' as Level },
      { name: 'Kotlin', level: 'intermediate' as Level },
      { name: 'JavaScript', level: 'advanced' as Level },
      { name: 'Bash', level: 'advanced' as Level },
      { name: 'SQL', level: 'expert' as Level },
    ],
  },
  {
    name: 'Data Engineering',
    icon: '[de]',
    skills: [
      { name: 'Airflow', level: 'expert' as Level },
      { name: 'dbt', level: 'advanced' as Level },
      { name: 'Prefect', level: 'advanced' as Level },
      { name: 'Pandas', level: 'intermediate' as Level },
      { name: 'Spark', level: 'intermediate' as Level },
    ],
  },
  {
    name: 'Backend',
    icon: '[be]',
    skills: [
      { name: 'Node.js', level: 'advanced' as Level },
      { name: 'FastAPI', level: 'expert' as Level },
      { name: 'Express', level: 'advanced' as Level },
      { name: 'GraphQL', level: 'intermediate' as Level },
      { name: 'REST APIs', level: 'expert' as Level },
    ],
  },
  {
    name: 'Frontend',
    icon: '[fe]',
    skills: [
      { name: 'React', level: 'advanced' as Level },
      { name: 'Next.js', level: 'advanced' as Level },
      { name: 'Astro', level: 'advanced' as Level },
      { name: 'Tailwind CSS', level: 'expert' as Level },
      { name: 'Vue.js', level: 'intermediate' as Level },
    ],
  },
  {
    name: 'Databases',
    icon: '[db]',
    skills: [
      { name: 'PostgreSQL', level: 'expert' as Level },
      { name: 'Redis', level: 'advanced' as Level },
      { name: 'Snowflake', level: 'intermediate' as Level },
      { name: 'MongoDB', level: 'intermediate' as Level },
      { name: 'Elasticsearch', level: 'intermediate' as Level },
      { name: 'Kafka', level: 'advanced' as Level },
    ],
  },
  {
    name: 'Cloud & Infrastructure',
    icon: '[cloud]',
    skills: [
      { name: 'Kubernetes', level: 'advanced' as Level },
      { name: 'Docker', level: 'expert' as Level },
      { name: 'AWS', level: 'advanced' as Level },
      { name: 'Terraform', level: 'advanced' as Level },
      { name: 'Helm', level: 'advanced' as Level },
    ],
  },
  {
    name: 'DevOps & Tools',
    icon: '[ops]',
    skills: [
      { name: 'Git', level: 'expert' as Level },
      { name: 'GitHub Actions', level: 'advanced' as Level },
      { name: 'GitLab CI/CD', level: 'expert' as Level },
      { name: 'Prometheus', level: 'intermediate' as Level },
      { name: 'Grafana', level: 'intermediate' as Level },
    ],
  },
];
---

<InnerLayout title="Skills" description="Technical skills and areas of expertise.">
  <div class="page-head">
    <div class="pg-num">§ 04 — expertise</div>
    <h1>Skills &amp; <span class="it">tools</span></h1>
    <p class="subtitle">Technologies and tools I work with to build modern software solutions.</p>
  </div>

  <!-- Legend -->
  <div class="section-block" style="padding-top:0;border-top:0">
    <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;font-size:11px;color:var(--ink-3)">
      <span style="letter-spacing:.1em;text-transform:uppercase;margin-right:4px">Proficiency:</span>
      {(['expert', 'advanced', 'intermediate', 'beginner'] as Level[]).map(lvl => (
        <span class="skill-tag">
          <span>{lvl}</span>
          <span class="pdots">
            {[1,2,3,4].map(i => (
              <span class={`pdot${i <= levels[lvl] ? ' on' : ''}`}></span>
            ))}
          </span>
        </span>
      ))}
    </div>
  </div>

  <!-- Skills grid -->
  <div class="entry-grid">
    {skillCategories.map((category) => (
      <div class="entry" style="min-height:auto">
        <div class="e-head" style="margin-bottom:14px">
          <div class="e-title" style="font-size:18px">{category.name}</div>
          <span style="font-size:10.5px;color:var(--ink-3)">{category.icon}</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          {category.skills.map((skill) => (
            <span class="skill-tag">
              <span>{skill.name}</span>
              <span class="pdots">
                {[1,2,3,4].map(i => (
                  <span class={`pdot${i <= levels[skill.level] ? ' on' : ''}`}></span>
                ))}
              </span>
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Footer note -->
  <div class="section-block">
    <div class="entry">
      <div class="e-title" style="font-size:16px;margin-bottom:8px">Always learning</div>
      <div class="e-body">Technology evolves rapidly, and I believe in continuous learning. Currently exploring: AI/ML and cloud infrastructure.</div>
    </div>
  </div>
</InnerLayout>
